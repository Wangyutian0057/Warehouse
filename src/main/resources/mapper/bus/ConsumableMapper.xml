<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yeqifu.bus.mapper.ConsumableMapper">
    <select id="loadConsumableCategoryStat" resultType="java.util.Map">
        SELECT type as name, SUM(quantity) as value FROM bus_consumable GROUP BY type
    </select>
</mapper>
